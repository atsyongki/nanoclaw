#!/bin/bash
set -euo pipefail

# docker-manager — Inspect and manage Docker containers and compose stacks
# Translates Windows paths (C:\docker\...) to WSL2 paths (/mnt/c/docker/...)

VERSION="1.0.0"
COMPOSE_MOUNT="${DOCKER_COMPOSE_DIR:-/mnt/c/docker}"

usage() {
  cat <<'USAGE'
docker-manager — Inspect and manage Docker containers and compose stacks

Usage:
  docker-manager status                      List all containers with their status
  docker-manager stopped                     List only stopped/exited containers
  docker-manager services <name>             List all services in a container's compose project
  docker-manager restart <name> [service]    Restart a service or entire compose stack
  docker-manager logs <name> [N]             Show last N lines of container logs (default: 50)
  docker-manager compose-list                List all detected compose projects
  docker-manager help                        Show this help

Restart behaviour:
  - If a specific [service] is given, restarts only that service in the stack
  - If container is stopped, does compose down + up (full recreation)
  - If container is running, does compose restart <service> (graceful)

Examples:
  docker-manager stopped
  docker-manager services overseerr
  docker-manager restart overseerr
  docker-manager restart mystack sonarr
  docker-manager logs sonarr 100
  docker-manager compose-list
USAGE
}

# Translate a Windows path like C:\docker\foo\bar.yaml to /mnt/c/docker/foo/bar.yaml
win_to_wsl() {
  local p="$1"
  # Already a Unix path
  if [[ "$p" == /* ]]; then
    echo "$p"
    return
  fi
  # C:\foo\bar -> /mnt/c/foo/bar
  echo "$p" | sed 's|^\([A-Za-z]\):\\|/mnt/\L\1/|; s|\\|/|g'
}

cmd="${1:-status}"
shift || true

case "$cmd" in
  status|list)
    echo "=== All Containers ==="
    docker ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Image}}" 2>/dev/null
    ;;

  stopped|down)
    echo "=== Stopped / Exited Containers ==="
    STOPPED=$(docker ps -a --filter "status=exited" --filter "status=dead" --format "{{.Names}}\t{{.Status}}\t{{.Image}}" 2>/dev/null)
    if [ -z "$STOPPED" ]; then
      echo "✓ All containers are running."
    else
      printf "%-40s %-30s %s\n" "NAME" "STATUS" "IMAGE"
      echo "$STOPPED" | while IFS=$'\t' read -r name status image; do
        printf "%-40s %-30s %s\n" "$name" "$status" "$image"
      done
    fi
    ;;

  services)
    CONTAINER="${1:-}"
    if [ -z "$CONTAINER" ]; then
      echo "Usage: docker-manager services <container-or-project-name>"
      exit 1
    fi

    # Try to find by container name first, then by project name
    CONFIG_FILES=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
    WORKING_DIR=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project.working_dir"}}' 2>/dev/null || true)
    PROJECT=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)

    # If not found by container name, search by project name across all containers
    if [ -z "$CONFIG_FILES" ]; then
      MATCH=$(docker ps -a --format '{{.Names}}' | while read -r c; do
        proj=$(docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)
        if [ "$proj" = "$CONTAINER" ]; then
          docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null
          break
        fi
      done)
      CONFIG_FILES="$MATCH"
    fi

    if [ -z "$CONFIG_FILES" ]; then
      echo "❌ No compose project found for '$CONTAINER'"
      exit 1
    fi

    CONFIG_WSL=$(win_to_wsl "$CONFIG_FILES")
    echo "📦 Compose project: ${PROJECT:-$CONTAINER}"
    echo "📄 Compose file:    $CONFIG_WSL"
    echo ""
    if [ -f "$CONFIG_WSL" ]; then
      echo "=== Services ==="
      docker compose -f "$CONFIG_WSL" config --services 2>/dev/null
    else
      echo "⚠️  Compose file not found at $CONFIG_WSL"
    fi
    ;;

  restart)
    CONTAINER="${1:-}"
    SERVICE="${2:-}"
    if [ -z "$CONTAINER" ]; then
      echo "Usage: docker-manager restart <container-or-service-name> [service]"
      exit 1
    fi

    # Get compose labels (works even on stopped containers)
    CONFIG_FILES=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
    WORKING_DIR=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project.working_dir"}}' 2>/dev/null || true)
    PROJECT=$(docker inspect "$CONTAINER" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)

    # If container name not found directly, try matching by compose service name
    if [ -z "$CONFIG_FILES" ]; then
      MATCHED_CONTAINER=""
      while read -r c; do
        svc=$(docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.service"}}' 2>/dev/null || true)
        if [ "$svc" = "$CONTAINER" ]; then
          MATCHED_CONTAINER="$c"
          CONFIG_FILES=$(docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
          WORKING_DIR=$(docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.project.working_dir"}}' 2>/dev/null || true)
          PROJECT=$(docker inspect "$c" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)
          # If no explicit service given, use the matched service name
          [ -z "$SERVICE" ] && SERVICE="$CONTAINER"
          break
        fi
      done < <(docker ps -a --format '{{.Names}}')
      [ -n "$MATCHED_CONTAINER" ] && CONTAINER="$MATCHED_CONTAINER"
    fi

    if [ -n "$CONFIG_FILES" ] && [ -n "$WORKING_DIR" ]; then
      # Translate Windows paths to WSL2 paths
      CONFIG_WSL=$(win_to_wsl "$CONFIG_FILES")
      WORKING_WSL=$(win_to_wsl "$WORKING_DIR")

      echo "📦 Compose project: $PROJECT"
      echo "📄 Compose file:    $CONFIG_WSL"
      echo "📁 Working dir:     $WORKING_WSL"
      [ -n "$SERVICE" ] && echo "🔧 Service:         $SERVICE"
      echo ""

      if [ ! -f "$CONFIG_WSL" ]; then
        echo "⚠️  Compose file not found at $CONFIG_WSL"
        echo "Falling back to simple container restart..."
        docker start "$CONTAINER"
        echo "✓ Container $CONTAINER started."
        exit 0
      fi

      # Check if the container is currently running or stopped
      STATE=$(docker inspect "$CONTAINER" --format '{{.State.Status}}' 2>/dev/null || echo "unknown")

      if [ "$STATE" = "running" ]; then
        # Container is running — use compose restart (graceful, no recreation)
        echo "🔄 Container is running — doing graceful restart..."
        if [ -n "$SERVICE" ]; then
          docker compose -f "$CONFIG_WSL" restart "$SERVICE"
          echo ""
          echo "✓ Service '$SERVICE' in project '$PROJECT' restarted."
        else
          docker compose -f "$CONFIG_WSL" restart
          echo ""
          echo "✓ All services in project '$PROJECT' restarted."
        fi
      else
        # Container is stopped — need full down + up
        echo "⏹  Container is stopped — recreating compose stack..."
        docker compose -f "$CONFIG_WSL" down
        echo "▶️  Starting compose stack..."
        if [ -n "$SERVICE" ]; then
          docker compose -f "$CONFIG_WSL" up -d "$SERVICE"
          echo ""
          echo "✓ Service '$SERVICE' in project '$PROJECT' started."
        else
          docker compose -f "$CONFIG_WSL" up -d
          echo ""
          echo "✓ Compose stack '$PROJECT' started."
        fi
      fi
    else
      echo "ℹ️  No compose project found for '$CONTAINER' — doing direct container restart..."
      docker start "$CONTAINER"
      echo "✓ Container $CONTAINER started."
    fi
    ;;

  logs)
    CONTAINER="${1:-}"
    LINES="${2:-50}"
    if [ -z "$CONTAINER" ]; then
      echo "Usage: docker-manager logs <container-name> [lines]"
      exit 1
    fi
    echo "=== Logs: $CONTAINER (last $LINES lines) ==="
    docker logs --tail "$LINES" "$CONTAINER" 2>&1
    ;;

  compose-list)
    echo "=== Compose Projects (discovered from container labels) ==="
    printf "%-30s %-50s %s\n" "PROJECT" "COMPOSE FILE" "CONTAINERS"
    echo "--------------------------------------------------------------------------------------------------------------"

    declare -A seen_projects
    while read -r container; do
      project=$(docker inspect "$container" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)
      [ -z "$project" ] && continue
      [ "${seen_projects[$project]+_}" ] && continue
      seen_projects["$project"]=1

      config_files=$(docker inspect "$container" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
      config_wsl=$(win_to_wsl "${config_files:-}")

      # Count containers in this project
      count=$(docker ps -a --filter "label=com.docker.compose.project=$project" --format '{{.Names}}' | wc -l)

      printf "%-30s %-50s %s container(s)\n" "$project" "${config_wsl:-unknown}" "$count"
    done < <(docker ps -a --format '{{.Names}}')

    # Show per-project container details
    declare -A seen2
    echo ""
    while read -r container; do
      project=$(docker inspect "$container" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || true)
      [ -z "$project" ] && continue
      [ "${seen2[$project]+_}" ] && continue
      seen2["$project"]=1

      echo ""
      echo "  [$project]"
      docker ps -a --filter "label=com.docker.compose.project=$project" \
        --format "    {{.Names}}\t{{.Status}}" | column -t
    done < <(docker ps -a --format '{{.Names}}')
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Unknown command: $cmd"
    usage
    exit 1
    ;;
esac
